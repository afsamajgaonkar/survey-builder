<%- include('partials/header') %>

<section class="analytics-section">
    <div class="container">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h1 class="page-title">Survey Analytics</h1>
                <p class="page-subtitle"><strong><%= survey.title %></strong> - Visualizing Responses</p>
            </div>
            <a href="/surveys/<%= survey.id %>/responses" class="btn btn-outline-glow">
                <i class="bi bi-arrow-left me-1"></i>Back to Responses
            </a>
        </div>

        <div id="analytics-container" class="row g-4">
            <div class="col-12 text-center py-5" id="loading-spinner">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
                <p class="mt-2 text-muted">Loading analytics data...</p>
            </div>
        </div>
    </div>
</section>

<!-- Include Chart.js -->
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
    document.addEventListener('DOMContentLoaded', async () => {
        try {
            const response = await fetch('/analytics/survey/<%= survey.id %>/data');
            const data = await response.json();
            
            const container = document.getElementById('analytics-container');
            const spinner = document.getElementById('loading-spinner');
            
            if (data.error) {
                spinner.innerHTML = `<div class="alert alert-danger">${data.error}</div>`;
                return;
            }

            if (data.length === 0) {
                spinner.innerHTML = `
                    <div class="glass-card text-center p-5 w-100 mt-4">
                        <i class="bi bi-bar-chart text-muted mb-3" style="font-size: 3rem;"></i>
                        <h3>No Data Available</h3>
                        <p class="text-muted">There are no responses to visualize yet for this survey.</p>
                        <a href="/surveys/${'<%= survey.id %>'}/responses" class="btn btn-primary-glow mt-3">Back</a>
                    </div>`;
                return;
            }

            // Remove spinner
            container.innerHTML = '';

            const backgroundColors = [
                'rgba(41, 128, 185, 0.8)',
                'rgba(155, 89, 182, 0.8)',
                'rgba(46, 204, 113, 0.8)',
                'rgba(241, 196, 15, 0.8)',
                'rgba(230, 126, 34, 0.8)',
                'rgba(231, 76, 60, 0.8)'
            ];

            // Render charts and text answers
            data.forEach((qData, index) => {
                const col = document.createElement('div');
                col.className = 'col-md-6 mb-4';

                let cardContent = `
                    <div class="glass-card p-4 h-100 d-flex flex-column">
                        <div class="d-flex justify-content-between align-items-start mb-4">
                            <h4 class="mb-0 flex-grow-1 pe-3">${qData.questionText}</h4>
                            <span class="badge bg-primary-subtle text-primary border border-primary-subtle">${qData.totalAnswers} Responses</span>
                        </div>
                `;

                if (['mcq', 'checkbox', 'rating', 'dropdown', 'yesno'].includes(qData.questionType)) {
                    if (qData.labels.length === 0) {
                        cardContent += `
                            <div class="flex-grow-1 d-flex align-items-center justify-content-center flex-column text-muted">
                                <i class="bi bi-inbox mb-2" style="font-size: 2rem;"></i>
                                <p>No data to visualize yet.</p>
                            </div>
                        </div>`;
                        col.innerHTML = cardContent;
                        container.appendChild(col);
                    } else {
                        cardContent += `
                            <div class="flex-grow-1 position-relative" style="min-height: 250px;">
                                <canvas id="chart-${index}"></canvas>
                            </div>
                        </div>`;
                        col.innerHTML = cardContent;
                        container.appendChild(col);

                        const ctx = document.getElementById(`chart-${index}`).getContext('2d');
                        const chartType = ['mcq', 'dropdown', 'yesno'].includes(qData.questionType) ? 'pie' : 'bar';

                        new Chart(ctx, {
                            type: chartType,
                            data: {
                                labels: qData.labels,
                                datasets: [{
                                    label: 'Responses',
                                    data: qData.data,
                                    backgroundColor: backgroundColors,
                                    borderColor: 'rgba(255, 255, 255, 0.1)',
                                    borderWidth: 1
                                }]
                            },
                            options: {
                                responsive: true,
                                maintainAspectRatio: false,
                                plugins: {
                                    legend: {
                                        position: 'bottom',
                                        labels: { color: '#e0e0e0' }
                                    }
                                },
                                scales: chartType === 'bar' ? {
                                    y: {
                                        beginAtZero: true,
                                        ticks: { stepSize: 1, color: '#e0e0e0' },
                                        grid: { color: 'rgba(255,255,255,0.1)' }
                                    },
                                    x: {
                                        ticks: { color: '#e0e0e0' },
                                        grid: { color: 'rgba(255,255,255,0.1)' }
                                    }
                                } : {}
                            }
                        });
                    }
                } else if (['short', 'long', 'datetime'].includes(qData.questionType)) {
                    cardContent += `
                        <div class="flex-grow-1 custom-scrollbar" style="max-height: 300px; overflow-y: auto; padding-right: 5px;">
                    `;
                    
                    if (qData.textAnswers && qData.textAnswers.length > 0) {
                        qData.textAnswers.forEach(ans => {
                            const dateStr = new Date(ans.date).toLocaleDateString();
                            cardContent += `
                                <div class="p-3 mb-2 rounded" style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.05);">
                                    <div class="d-flex justify-content-between align-items-center mb-2">
                                        <small class="text-info fw-bold"><i class="bi bi-person-fill me-1"></i>${ans.respondent}</small>
                                        <small class="text-white" style="font-size: 0.75rem; opacity: 0.8;">${dateStr}</small>
                                    </div>
                                    <p class="mb-0 text-light" style="font-size: 0.95rem; white-space: pre-wrap;">${ans.text}</p>
                                </div>
                            `;
                        });
                    } else {
                        cardContent += `
                            <div class="h-100 d-flex align-items-center justify-content-center flex-column text-muted py-4">
                                <i class="bi bi-chat-square-text mb-2" style="font-size: 2rem;"></i>
                                <p>No text responses yet.</p>
                            </div>
                        `;
                    }
                    
                    cardContent += `</div></div>`;
                    col.innerHTML = cardContent;
                    container.appendChild(col);
                }
            });

        } catch (err) {
            console.error('Error fetching analytics:', err);
            document.getElementById('loading-spinner').innerHTML = '<div class="alert alert-danger">Failed to load analytics data.</div>';
        }
    });
</script>

<%- include('partials/footer') %>
