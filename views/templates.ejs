<%- include('partials/header') %>

<section class="templates-section">
    <div class="container">
        <!-- Header -->
        <div class="d-flex align-items-center gap-3 mb-2 mt-2">
            <a href="/dashboard" class="btn btn-sm btn-outline-glow">
                <i class="bi bi-arrow-left me-1"></i>Dashboard
            </a>
            <h1 class="page-title mb-0"><i class="bi bi-grid-1x2-fill me-2"></i>Survey Templates</h1>
        </div>
        <p class="page-subtitle mb-5">Start fast with a pre-built template — customize it however you like.</p>

        <% const categoryIcons = { Business:'briefcase-fill', HR:'people-fill', Events:'calendar-event-fill', Product:'box-seam-fill', Education:'mortarboard-fill' }; %>

        <% Object.keys(grouped).forEach(function(category) { %>
        <div class="mb-5">
            <h2 class="templates-category-title">
                <i class="bi bi-<%= categoryIcons[category] || 'folder-fill' %> me-2"></i><%= category %>
            </h2>
            <div class="row g-4">
                <% grouped[category].forEach(function(t) { %>
                <div class="col-lg-4 col-md-6">
                    <div class="template-card glass-card h-100">
                        <div class="template-card-body">
                            <div class="template-icon">
                                <i class="bi bi-file-earmark-text-fill"></i>
                            </div>
                            <h3 class="template-title"><%= t.name %></h3>
                            <p class="template-desc"><%= t.description %></p>
                            <div class="template-meta">
                                <span class="template-badge">
                                    <i class="bi bi-question-circle-fill me-1"></i>
                                    <%= Array.isArray(t.questions) ? t.questions.length : JSON.parse(t.questions).length %> questions
                                </span>
                                <span class="template-badge">
                                    <i class="bi bi-tag-fill me-1"></i><%= t.category %>
                                </span>
                            </div>
                        </div>
                        <div class="template-card-footer">
                            <form action="/templates/<%= t.id %>/use" method="POST">
                                <button type="submit" class="btn btn-primary-glow w-100">
                                    <i class="bi bi-lightning-fill me-2"></i>Use This Template
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
                <% }); %>
            </div>
        </div>
        <% }); %>

        <!-- Create from scratch CTA -->
        <div class="glass-card p-4 text-center mb-5" style="border:2px dashed rgba(102,126,234,0.3);">
            <i class="bi bi-pencil-square" style="font-size:2rem;color:#667eea;"></i>
            <h3 class="mt-3 mb-1" style="color:#fff;">Prefer to start from scratch?</h3>
            <p style="color: var(--text-secondary);" class="mb-3">Build your own survey with complete control over every question.</p>
            <a href="/surveys/new" class="btn btn-outline-glow">
                <i class="bi bi-plus-circle me-2"></i>Create Blank Survey
            </a>
        </div>
    </div>
</section>

<style>
.templates-section { padding: 40px 0 60px; }
.templates-category-title {
    font-size: 1.2rem;
    font-weight: 700;
    color: #fff;
    margin-bottom: 20px;
    padding-bottom: 10px;
    border-bottom: 1px solid rgba(255,255,255,0.08);
}
.template-card {
    display: flex;
    flex-direction: column;
    border-radius: 16px;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
    overflow: hidden;
}
.template-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 16px 40px rgba(102,126,234,0.2);
}
.template-card-body { flex: 1; padding: 24px; }
.template-card-footer { padding: 16px 24px; border-top: 1px solid rgba(255,255,255,0.06); }
.template-icon {
    width: 52px; height: 52px;
    background: linear-gradient(135deg, #667eea, #764ba2);
    border-radius: 12px;
    display: flex; align-items: center; justify-content: center;
    font-size: 22px; color: #fff;
    margin-bottom: 16px;
}
.template-title { font-size: 1.05rem; font-weight: 700; color: #fff; margin-bottom: 8px; }
.template-desc { color: #a0a0c0; font-size: 0.87rem; line-height: 1.5; margin-bottom: 14px; }
.template-meta { display: flex; gap: 8px; flex-wrap: wrap; }
.template-badge {
    background: rgba(102,126,234,0.15);
    border: 1px solid rgba(102,126,234,0.25);
    color: #b0b0e0;
    border-radius: 20px;
    padding: 4px 10px;
    font-size: 0.78rem;
}
</style>

<%- include('partials/footer') %>
