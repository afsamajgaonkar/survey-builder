<%- include('partials/header') %>

    <section class="auth-section">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-lg-10">
                    <div class="auth-container glass-card">
                        <div class="row g-0">
                            <!-- Left - Illustration panel -->
                            <div class="col-lg-6 d-none d-lg-flex auth-illustration-panel">
                                <div class="auth-illustration-content">
                                    <div class="auth-illustration-icon">
                                        <i class="bi bi-person-plus-fill"></i>
                                    </div>
                                    <h2>Join SurveyBuilder</h2>
                                    <p>Create an account and start building surveys in minutes.</p>
                                    <div class="auth-features-list">
                                        <div class="auth-feature-item">
                                            <i class="bi bi-check-circle-fill"></i>
                                            <span>Free to use, no limits</span>
                                        </div>
                                        <div class="auth-feature-item">
                                            <i class="bi bi-check-circle-fill"></i>
                                            <span>5+ question types</span>
                                        </div>
                                        <div class="auth-feature-item">
                                            <i class="bi bi-check-circle-fill"></i>
                                            <span>Secure data storage</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <!-- Right - Register Form -->
                            <div class="col-lg-6">
                                <div class="auth-form-panel">
                                    <h2 class="auth-title">Create Account</h2>
                                    <p class="auth-subtitle">Fill in your details to get started</p>

                                    <% if (typeof errors !=='undefined' && errors.length> 0) { %>
                                        <% errors.forEach(function(err) { %>
                                            <div class="alert alert-danger glass-alert"><i
                                                    class="bi bi-exclamation-triangle-fill me-2"></i>
                                                <%= err.msg %>
                                            </div>
                                            <% }); %>
                                                <% } %>

                                                    <form action="/auth/register" method="POST" id="registerForm">
                                                        <div class="row">
                                                            <div class="col-md-6">
                                                                <div class="form-floating-custom mb-3">
                                                                    <label for="firstName"><i
                                                                            class="bi bi-person-fill me-2"></i>First
                                                                        Name</label>
                                                                    <input type="text" class="form-control"
                                                                        id="firstName" name="firstName"
                                                                        placeholder="First Name"
                                                                        value="<%= typeof firstName !== 'undefined' ? firstName : '' %>"
                                                                        required pattern="[A-Za-z\s]+">
                                                                </div>
                                                            </div>
                                                            <div class="col-md-6">
                                                                <div class="form-floating-custom mb-3">
                                                                    <label for="lastName"><i
                                                                            class="bi bi-person-fill me-2"></i>Last
                                                                        Name</label>
                                                                    <input type="text" class="form-control"
                                                                        id="lastName" name="lastName"
                                                                        placeholder="Last Name"
                                                                        value="<%= typeof lastName !== 'undefined' ? lastName : '' %>"
                                                                        required pattern="[A-Za-z\s]+"
                                                                        title="Last name must contain only letters">
                                                                </div>
                                                            </div>
                                                        </div>
                                                        <div class="form-floating-custom mb-3">
                                                            <label for="email"><i
                                                                    class="bi bi-envelope-fill me-2"></i>Email
                                                                Address</label>
                                                            <input type="email" class="form-control" id="email"
                                                                name="email" placeholder="Enter your email"
                                                                value="<%= typeof email !== 'undefined' ? email : '' %>"
                                                                required
                                                                oninvalid="this.setCustomValidity('Please enter the correct credential')"
                                                                oninput="this.setCustomValidity('')">
                                                        </div>
                                                        <div class="form-floating-custom mb-3">
                                                            <label for="password"><i
                                                                    class="bi bi-lock-fill me-2"></i>Password</label>
                                                            <input type="password" class="form-control" id="password"
                                                                name="password"
                                                                placeholder="At least 8 characters with letters & numbers"
                                                                required minlength="8"
                                                                pattern="^(?=.*[A-Za-z])(?=.*[0-9]).{8,}$"
                                                                title="Password must be at least 8 characters and include both letters and numbers">
                                                            <label class="form-text"
                                                                style="font-size: 0.75rem; margin-top: 5px;">
                                                                Must be at least 8 characters with at least one letter and one number.
                                                                Special characters are allowed.
                                                            </label>
                                                        </div>
                                                        <div class="form-floating-custom mb-4">
                                                            <label for="password2"><i
                                                                    class="bi bi-lock-fill me-2"></i>Confirm
                                                                Password</label>
                                                            <input type="password" class="form-control" id="password2"
                                                                name="password2" placeholder="Re-enter your password"
                                                                required minlength="8">
                                                        </div>
                                                        <button type="submit"
                                                            class="btn btn-primary-glow w-100 btn-lg mb-3">
                                                            <i class="bi bi-person-plus-fill me-2"></i>Create Account
                                                        </button>
                                                    </form>
                                                    <div class="auth-divider">
                                                        <span>Already have an account?</span>
                                                    </div>
                                                    <a href="/auth/login" class="btn btn-outline-glow w-100">
                                                        <i class="bi bi-box-arrow-in-right me-2"></i>Log In
                                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <%- include('partials/footer') %>

        <script>
            document.addEventListener('DOMContentLoaded', () => {
                const registerForm = document.getElementById('registerForm');
                if (registerForm) {
                    registerForm.addEventListener('submit', (e) => {
                        const btn = registerForm.querySelector('button[type="submit"]');
                        if (btn) {
                            // Prevent double clicks
                            if (btn.disabled) {
                                e.preventDefault();
                                return;
                            }
                            btn.disabled = true;
                            const originalText = btn.innerHTML;
                            btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>Creating...';
                        }
                    });
                }
            });
        </script>