<%- include('partials/header') %>

    <section class="admin-section">
        <div class="container">
            <div class="dashboard-header mb-4">
                <div class="d-flex align-items-center gap-3">
                    <a href="/admin" class="btn btn-outline-glow"><i class="bi bi-arrow-left"></i> Back</a>
                    <div>
                        <h1 class="page-title">User Details: <%= targetUser.username %></h1>
                        <p class="page-subtitle"><%= targetUser.email %> | Role: <%= targetUser.role %> | Joined: <%= new Date(targetUser.created_at).toLocaleDateString() %></p>
                    </div>
                </div>
            </div>

            <div class="row g-4">
                <!-- User Surveys -->
                <div class="col-lg-8">
                    <div class="glass-card p-4 mb-4">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h3 class="card-section-title"><i class="bi bi-clipboard2-data-fill me-2"></i>Active Surveys (<%= userSurveys.length %>)</h3>
                        </div>
                        <div class="table-responsive">
                            <table class="table table-dark-custom">
                                <thead>
                                    <tr>
                                        <th>Title</th>
                                        <th>Responses</th>
                                        <th>Status</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% if (userSurveys.length > 0) { %>
                                        <% userSurveys.forEach(function(s) { %>
                                            <tr>
                                                <td><%= s.title %></td>
                                                <td><%= s.response_count %></td>
                                                <td><span class="badge <%= s.is_active ? 'badge-active' : 'badge-inactive' %>"><%= s.is_active ? 'Active' : 'Inactive' %></span></td>
                                                <td>
                                                    <div class="d-flex gap-2">
                                                        <a href="/surveys/<%= s.id %>/preview" class="btn btn-sm btn-outline-success" title="Preview Survey"><i class="bi bi-eye"></i></a>
                                                        <a href="/surveys/<%= s.id %>/responses" class="btn btn-sm btn-outline-info" title="View Responses"><i class="bi bi-bar-chart-fill"></i></a>
                                                        <form action="/surveys/<%= s.id %>/delete" method="POST" class="d-inline" onsubmit="return confirm('Delete this survey permanently?');">
                                                            <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete Survey"><i class="bi bi-trash"></i></button>
                                                        </form>
                                                    </div>
                                                </td>
                                            </tr>
                                        <% }); %>
                                    <% } else { %>
                                        <tr><td colspan="4" class="text-center text-muted py-3">No active surveys</td></tr>
                                    <% } %>
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <!-- Trashed Surveys -->
                    <div class="glass-card p-4 mb-4">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h3 class="card-section-title text-danger"><i class="bi bi-trash-fill me-2"></i>Recycle Bin (<%= trashedSurveys.length %>)</h3>
                        </div>
                        <div class="table-responsive">
                            <table class="table table-dark-custom">
                                <thead>
                                    <tr>
                                        <th>Title</th>
                                        <th>Responses</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% if (trashedSurveys.length > 0) { %>
                                        <% trashedSurveys.forEach(function(s) { %>
                                            <tr>
                                                <td><del><%= s.title %></del></td>
                                                <td><%= s.response_count %></td>
                                                <td>
                                                    <div class="d-flex gap-2">
                                                        <form action="/surveys/<%= s.id %>/restore" method="POST" class="d-inline">
                                                            <button type="submit" class="btn btn-sm btn-outline-success" title="Restore"><i class="bi bi-arrow-counterclockwise"></i></button>
                                                        </form>
                                                        <form action="/surveys/<%= s.id %>/delete" method="POST" class="d-inline" onsubmit="return confirm('Delete this survey permanently?');">
                                                            <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete Permanently"><i class="bi bi-trash"></i></button>
                                                        </form>
                                                    </div>
                                                </td>
                                            </tr>
                                        <% }); %>
                                    <% } else { %>
                                        <tr><td colspan="3" class="text-center text-muted py-3">Recycle bin is empty</td></tr>
                                    <% } %>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <!-- User Activities -->
                <div class="col-lg-4">
                    <div class="glass-card p-4">
                        <h3 class="card-section-title"><i class="bi bi-activity me-2"></i>Activity Log</h3>
                        <div class="mt-3">
                            <% if (userActivities && userActivities.length > 0) { %>
                                <ul class="list-group list-group-flush bg-transparent">
                                    <% userActivities.forEach(function(act) { %>
                                        <li class="list-group-item bg-transparent border-secondary text-white px-0 py-2">
                                            <div class="d-flex justify-content-between align-items-center">
                                                <div>
                                                    <div class="d-flex justify-content-between">
                                                        <small class="text-muted"><%= new Date(act.created_at).toLocaleDateString() %> <%= new Date(act.created_at).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'}) %></small>
                                                    </div>
                                                    <div><%= act.action %></div>
                                                </div>
                                                <form action="/admin/activity/<%= act.id %>/delete" method="POST" class="d-inline" onsubmit="return confirm('Are you sure you want to delete this activity?');">
                                                    <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete Activity"><i class="bi bi-trash"></i></button>
                                                </form>
                                            </div>
                                        </li>
                                    <% }); %>
                                </ul>
                            <% } else { %>
                                <p class="text-muted text-center py-4">No activity recorded</p>
                            <% } %>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

<%- include('partials/footer') %>
