<%- include('partials/header') %>

    <section class="error-section">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-lg-6 text-center">
                    <div class="glass-card p-5 error-card">
                        <div class="closed-icon mb-3">
                            <i class="bi bi-lock-fill"></i>
                        </div>
                        <h2 class="mt-3 mb-2">Survey Closed</h2>
                        <p class="text-muted mb-4">"<strong>
                                <%= survey.title %>
                            </strong>" is no longer accepting responses.</p>
                        <a href="/" class="btn btn-primary-glow">
                            <i class="bi bi-house-fill me-2"></i>Go Home
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <%- include('partials/footer') %>