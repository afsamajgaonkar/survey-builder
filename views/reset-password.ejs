<%- include('partials/header') %>

<section class="auth-section">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-6 col-md-8">
                <div class="auth-container glass-card">
                    <div class="auth-form-panel p-5">
                        <h2 class="auth-title">Reset Password</h2>
                        <p class="auth-subtitle">Set a new password for <%= email %></p>

                        <% if (typeof errors !== 'undefined' && errors.length > 0) { %>
                            <% errors.forEach(function(err) { %>
                                <div class="alert alert-danger glass-alert"><i class="bi bi-exclamation-triangle-fill me-2"></i><%= err.msg %></div>
                            <% }); %>
                        <% } %>
                        <% if (typeof error !== 'undefined' && error != '') { %>
                            <div class="alert alert-danger glass-alert"><i class="bi bi-exclamation-triangle-fill me-2"></i><%= error %></div>
                        <% } %>
                        <% if (typeof error_msg !== 'undefined' && error_msg != '') { %>
                            <div class="alert alert-danger glass-alert"><i class="bi bi-exclamation-triangle-fill me-2"></i><%= error_msg %></div>
                        <% } %>

                        <form action="/auth/reset-password" method="POST">
                            <input type="hidden" name="email" value="<%= email %>">
                            
                            <div class="form-floating-custom mb-3">
                                <label for="password"><i class="bi bi-lock-fill me-2"></i>New Password</label>
                                <input type="password" class="form-control" id="password" name="password" placeholder="Minimum 6 characters" required minlength="6">
                            </div>
                            
                            <div class="form-floating-custom mb-4">
                                <label for="password2"><i class="bi bi-lock-fill me-2"></i>Confirm New Password</label>
                                <input type="password" class="form-control" id="password2" name="password2" placeholder="Re-enter your new password" required minlength="6">
                            </div>
                            
                            <button type="submit" class="btn btn-primary-glow w-100 btn-lg">
                                <i class="bi bi-check-circle-fill me-2"></i>Reset Password
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<%- include('partials/footer') %>
