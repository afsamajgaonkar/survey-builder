<%- include('partials/header') %>

<section class="builder-section">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-10">
                <!-- Header -->
                <div class="builder-header mb-4">
                    <div class="d-flex align-items-center gap-3 mb-2">
                        <a href="/dashboard" class="btn btn-sm btn-outline-glow">
                            <i class="bi bi-arrow-left me-1"></i>Dashboard
                        </a>
                        <h1 class="page-title mb-0">
                            <%= survey ? 'Edit Survey' : 'Create New Survey' %>
                        </h1>
                    </div>
                    <p class="page-subtitle">
                        <%= survey ? 'Update your survey details and questions' : 'Design your survey with multiple question types' %>
                    </p>
                </div>

                <form action="<%= survey ? '/surveys/' + survey.id + '/update' : '/surveys' %>" method="POST" id="surveyForm">

                    <!-- Survey Details -->
                    <div class="glass-card p-4 mb-4">
                        <h3 class="card-section-title"><i class="bi bi-info-circle-fill me-2"></i>Survey Details</h3>
                        <div class="form-floating-custom mb-3">
                            <label for="title">Survey Title <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" id="title" name="title"
                                placeholder="e.g. Customer Satisfaction Survey"
                                value="<%= survey ? survey.title : '' %>" required>
                        </div>
                        <div class="form-floating-custom mb-3">
                            <label for="description">Description</label>
                            <textarea class="form-control" id="description" name="description" rows="3"
                                placeholder="Brief description of your survey"><%= survey ? survey.description : '' %></textarea>
                        </div>
                        <% if (survey) { %>
                        <div class="form-check form-switch mb-3">
                            <input class="form-check-input" type="checkbox" id="is_active" name="is_active"
                                value="true" <%= survey.is_active ? 'checked' : '' %>>
                            <label class="form-check-label" for="is_active">Survey is Active (accepting responses)</label>
                        </div>
                        <% } %>
                        <div class="form-floating-custom mb-3">
                            <label for="expiry_date">Expiry Date (Optional)</label>
                            <input type="datetime-local" class="form-control" id="expiry_date" name="expiry_date"
                                min="<%= new Date(new Date().getTime() - new Date().getTimezoneOffset() * 60000).toISOString().slice(0, 16) %>"
                                value="<%= survey && survey.expiry_date ? new Date(survey.expiry_date.getTime() - survey.expiry_date.getTimezoneOffset() * 60000).toISOString().slice(0, 16) : '' %>">
                        </div>
                    </div>



                    <!-- Questions Container -->
                    <div class="glass-card p-4 mb-4">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h3 class="card-section-title mb-0"><i class="bi bi-list-check me-2"></i>Questions</h3>
                            <div class="btn-group">
                                <button type="button" class="btn btn-sm btn-primary-glow dropdown-toggle" data-bs-toggle="dropdown">
                                    <i class="bi bi-plus-lg me-1"></i>Add Question
                                </button>
                                <ul class="dropdown-menu">
                                    <li><a class="dropdown-item" href="#" onclick="addQuestion('mcq')"><i class="bi bi-ui-radios me-2"></i>Multiple Choice</a></li>
                                    <li><a class="dropdown-item" href="#" onclick="addQuestion('short')"><i class="bi bi-input-cursor-text me-2"></i>Short Answer</a></li>
                                    <li><a class="dropdown-item" href="#" onclick="addQuestion('long')"><i class="bi bi-textarea-resize me-2"></i>Long Answer</a></li>
                                    <li><a class="dropdown-item" href="#" onclick="addQuestion('checkbox')"><i class="bi bi-check2-square me-2"></i>Checkbox</a></li>
                                    <li><a class="dropdown-item" href="#" onclick="addQuestion('rating')"><i class="bi bi-star-fill me-2"></i>Rating Scale</a></li>
                                    <li><hr class="dropdown-divider" style="border-color: rgba(255,255,255,0.1);"></li>
                                    <li><a class="dropdown-item" href="#" onclick="addQuestion('dropdown')"><i class="bi bi-menu-button-wide me-2"></i>Dropdown</a></li>
                                    <li><a class="dropdown-item" href="#" onclick="addQuestion('yesno')"><i class="bi bi-toggle-on me-2"></i>Yes/No</a></li>
                                    <li><a class="dropdown-item" href="#" onclick="addQuestion('datetime')"><i class="bi bi-calendar-time me-2"></i>Date/Time</a></li>
                                </ul>
                            </div>
                        </div>

                        <div id="questionsContainer">
                            <% if (questions && questions.length > 0) { %>
                                <% questions.forEach(function(q, index) { %>
                                    <!-- Pre-populated questions are handled by JS -->
                                <% }); %>
                            <% } %>
                        </div>

                        <div id="emptyQuestionsMsg" class="empty-questions text-center py-4" style="display: none;">
                            <i class="bi bi-plus-circle" style="font-size: 2rem; opacity: 0.5;"></i>
                            <p class="text-white mt-2">Click "Add Question" to start building your survey</p>
                        </div>
                    </div>

                    <!-- Skip Logic — Module 6 -->
                    <div class="glass-card p-4 mb-4" id="skipLogicPanel" style="display:none;">
                        <h3 class="card-section-title"><i class="bi bi-arrow-left-right me-2"></i>Skip Logic</h3>
                        <p class="text-muted mb-3" style="font-size:0.85rem;">Automatically skip to a different question based on an answer.</p>
                        <div id="skipRulesContainer"></div>
                        <button type="button" class="btn btn-sm btn-outline-glow mt-2" onclick="addSkipRule()">
                            <i class="bi bi-plus-lg me-1"></i>Add Skip Rule
                        </button>
                    </div>

                    <!-- Submit -->
                    <div class="d-flex gap-3 justify-content-end mb-5">
                        <a href="/dashboard" class="btn btn-outline-glow btn-lg">Cancel</a>
                        <button type="submit" class="btn btn-primary-glow btn-lg" id="submitBtn">
                            <i class="bi bi-check-lg me-2"></i>
                            <%= survey ? 'Update Survey' : 'Create Survey' %>
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</section>

<style>


/* ── Skip Logic ─────────────────────────────────────────────────────────────── */
.skip-rule-row {
    display: flex;
    align-items: center;
    gap: 8px;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.07);
    border-radius: 10px;
    padding: 10px 14px;
    margin-bottom: 8px;
    flex-wrap: wrap;
}
.skip-rule-row select, .skip-rule-row input {
    background: rgba(0,0,0,0.3);
    border: 1px solid rgba(255,255,255,0.12);
    color: #fff;
    border-radius: 8px;
    padding: 6px 10px;
    font-size: 0.85rem;
    min-width: 120px;
}
.skip-rule-row label { color: #a0a0c0; font-size: 0.82rem; white-space: nowrap; }
</style>

<!-- Pass existing questions + skip rules to JS -->
<script>
    const existingQuestions = <%- JSON.stringify(questions || []) %>;
    const surveyId = '<%= survey ? survey.id : "" %>';
</script>
<script src="/js/survey-builder.js?v=2"></script>

<script>

// ── Skip Logic UI ─────────────────────────────────────────────────────────
function updateSkipLogicPanel() {
    const container = document.getElementById('questionsContainer');
    const panel = document.getElementById('skipLogicPanel');
    if (!container || !panel) return;
    const qCount = container.querySelectorAll('.question-card').length;
    panel.style.display = qCount >= 2 ? 'block' : 'none';
}
// Observe question additions
const _obs = new MutationObserver(updateSkipLogicPanel);
const _qc = document.getElementById('questionsContainer');
if (_qc) _obs.observe(_qc, { childList: true });

function addSkipRule() {
    const container = document.getElementById('skipRulesContainer');
    const qCards = document.querySelectorAll('#questionsContainer .question-card');
    if (qCards.length < 2) return;

    const row = document.createElement('div');
    row.className = 'skip-rule-row';

    let qOptions = '<option value="">-- Select Question --</option>';
    qCards.forEach((card, i) => {
        const label = card.querySelector('input[name$="[text]"]');
        const text = label ? (label.value.substring(0, 40) || `Question ${i + 1}`) : `Question ${i + 1}`;
        qOptions += `<option value="${i}">${i + 1}. ${text}</option>`;
    });

    row.innerHTML = `
        <label>If</label>
        <select class="skip-from" name="skip_from[]">${qOptions}</select>
        <label>answer is</label>
        <input type="text" name="skip_condition[]" placeholder="e.g. Yes" style="max-width:120px;">
        <label>→ skip to</label>
        <select class="skip-to" name="skip_to[]">${qOptions}</select>
        <button type="button" onclick="this.closest('.skip-rule-row').remove()"
            style="background:rgba(244,63,94,0.15);border:1px solid rgba(244,63,94,0.3);color:#f43f5e;
                   border-radius:6px;padding:4px 10px;cursor:pointer;">✕</button>
    `;
    container.appendChild(row);
}
</script>

<%- include('partials/footer') %>