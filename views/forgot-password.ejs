<%- include('partials/header') %>

<section class="auth-section">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-6 col-md-8">
                <div class="auth-container glass-card">
                    <div class="auth-form-panel p-5">
                        <h2 class="auth-title">Forgot Password</h2>
                        <p class="auth-subtitle">Enter your email address to reset your password</p>

                        <% if (typeof errors !== 'undefined' && errors.length > 0) { %>
                            <% errors.forEach(function(err) { %>
                                <div class="alert alert-danger glass-alert"><i class="bi bi-exclamation-triangle-fill me-2"></i><%= err.msg %></div>
                            <% }); %>
                        <% } %>
                        <% if (typeof error !== 'undefined' && error != '') { %>
                            <div class="alert alert-danger glass-alert"><i class="bi bi-exclamation-triangle-fill me-2"></i><%= error %></div>
                        <% } %>
                        <% if (typeof error_msg !== 'undefined' && error_msg != '') { %>
                            <div class="alert alert-danger glass-alert"><i class="bi bi-exclamation-triangle-fill me-2"></i><%= error_msg %></div>
                        <% } %>

                        <form action="/auth/forgot-password" method="POST">
                            <div class="form-floating-custom mb-4">
                                <label for="email"><i class="bi bi-envelope-fill me-2"></i>Email Address</label>
                                <input type="email" class="form-control" id="email" name="email" placeholder="Enter your email" value="<%= typeof email !== 'undefined' ? email : '' %>" required>
                            </div>
                            
                            <button type="submit" class="btn btn-primary-glow w-100 btn-lg mb-3">
                                <i class="bi bi-arrow-right-circle-fill me-2"></i>Continue
                            </button>
                        </form>
                        
                        <div class="auth-divider">
                            <span>Remember your password?</span>
                        </div>
                        <a href="/auth/login" class="btn btn-outline-glow w-100">
                            <i class="bi bi-box-arrow-in-right me-2"></i>Sign In
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<%- include('partials/footer') %>
