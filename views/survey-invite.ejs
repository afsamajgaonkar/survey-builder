<%- include('partials/header') %>

<section class="invite-section">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-9">
                <!-- Header -->
                <div class="d-flex align-items-center gap-3 mb-4">
                    <a href="/dashboard" class="btn btn-sm btn-outline-glow">
                        <i class="bi bi-arrow-left me-1"></i>Dashboard
                    </a>
                    <div>
                        <h1 class="page-title mb-0"><i class="bi bi-envelope-paper-fill me-2"></i>Email Invitations</h1>
                        <p class="text-muted mb-0" style="font-size:0.88rem;"><%= survey.title %></p>
                    </div>
                </div>

                <!-- Send Form -->
                <div class="glass-card p-4 mb-4">
                    <h3 class="card-section-title"><i class="bi bi-send-fill me-2"></i>Send Invitations</h3>
                    <form action="/surveys/<%= survey.id %>/invitations" method="POST">
                        <div class="form-floating-custom mb-3">
                            <label for="emails">
                                <i class="bi bi-people-fill me-2"></i>Email Addresses
                            </label>
                            <textarea class="form-control" id="emails" name="emails" rows="4"
                                placeholder="Enter email addresses separated by commas, spaces, or new lines&#10;e.g.&#10;alice@example.com, bob@example.com&#10;carol@example.com"></textarea>
                        </div>
                        <div class="d-flex justify-content-between align-items-center">
                            <p class="text-muted mb-0" style="font-size:0.82rem;">
                                <i class="bi bi-info-circle me-1"></i>Separate multiple emails with commas or new lines.
                            </p>
                            <button type="submit" class="btn btn-primary-glow">
                                <i class="bi bi-send-fill me-2"></i>Send Invitations
                            </button>
                        </div>
                    </form>
                </div>

                <!-- Survey Share Link -->
                <div class="glass-card p-3 mb-4">
                    <div class="d-flex align-items-center gap-3">
                        <i class="bi bi-link-45deg" style="font-size:1.4rem;color:#667eea;"></i>
                        <div class="flex-grow-1">
                            <div style="font-size:0.8rem;color:#a0a0c0;margin-bottom:3px;">Public Survey Link</div>
                            <code style="color:#c5c5f0;font-size:0.85rem;" id="shareUrlDisplay">
                                <%= (process.env.BASE_URL || 'http://localhost:3000') + '/s/' + survey.share_link %>
                            </code>
                        </div>
                        <button class="btn btn-sm btn-outline-glow" onclick="copyShareUrl()">
                            <i class="bi bi-clipboard"></i>
                        </button>
                    </div>
                </div>

                <!-- Invitation List -->
                <div class="glass-card p-4">
                    <h3 class="card-section-title"><i class="bi bi-list-check me-2"></i>
                        Invitation Status (<%= invitations.length %>)
                    </h3>

                    <% if (invitations.length === 0) { %>
                    <div class="text-center py-4">
                        <i class="bi bi-envelope-open" style="font-size:2.5rem;color:#555;"></i>
                        <p class="text-muted mt-3">No invitations sent yet. Use the form above to invite respondents.</p>
                    </div>
                    <% } else { %>
                    <div class="table-responsive">
                        <table class="table table-dark table-borderless align-middle">
                            <thead>
                                <tr style="border-bottom:1px solid rgba(255,255,255,0.08);">
                                    <th style="color:#a0a0c0;">Email</th>
                                    <th style="color:#a0a0c0;">Sent</th>
                                    <th style="color:#a0a0c0;">Opened</th>
                                    <th style="color:#a0a0c0;">Responded</th>
                                    <th style="color:#a0a0c0;">Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% invitations.forEach(function(inv) { %>
                                <tr style="border-bottom:1px solid rgba(255,255,255,0.04);">
                                    <td style="color:#fff;font-size:0.9rem;"><%= inv.email %></td>
                                    <td style="color:#a0a0c0;font-size:0.82rem;">
                                        <%= new Date(inv.sent_at).toLocaleDateString() %>
                                    </td>
                                    <td>
                                        <% if (inv.opened_at) { %>
                                            <span style="color:#48c78e;font-size:0.82rem;">
                                                <i class="bi bi-eye-fill me-1"></i>
                                                <%= new Date(inv.opened_at).toLocaleDateString() %>
                                            </span>
                                        <% } else { %>
                                            <span style="color:#555;font-size:0.82rem;">—</span>
                                        <% } %>
                                    </td>
                                    <td>
                                        <% if (inv.responded_at) { %>
                                            <span style="color:#48c78e;font-size:0.82rem;">
                                                <i class="bi bi-check-circle-fill me-1"></i>
                                                <%= new Date(inv.responded_at).toLocaleDateString() %>
                                            </span>
                                        <% } else { %>
                                            <span style="color:#555;font-size:0.82rem;">—</span>
                                        <% } %>
                                    </td>
                                    <td>
                                        <% if (inv.responded_at) { %>
                                            <span class="badge" style="background:rgba(72,199,142,0.2);color:#48c78e;border:1px solid rgba(72,199,142,0.3);">Responded</span>
                                        <% } else if (inv.opened_at) { %>
                                            <span class="badge" style="background:rgba(255,193,7,0.15);color:#ffc107;border:1px solid rgba(255,193,7,0.3);">Opened</span>
                                        <% } else { %>
                                            <span class="badge" style="background:rgba(160,160,160,0.1);color:#a0a0c0;border:1px solid rgba(160,160,160,0.2);">Sent</span>
                                        <% } %>
                                    </td>
                                </tr>
                                <% }); %>
                            </tbody>
                        </table>
                    </div>

                    <!-- Stats summary -->
                    <div class="d-flex gap-3 mt-3 flex-wrap">
                        <div class="invite-stat">
                            <div class="invite-stat-num"><%= invitations.length %></div>
                            <div class="invite-stat-label">Invited</div>
                        </div>
                        <div class="invite-stat">
                            <div class="invite-stat-num" style="color:#ffc107;">
                                <%= invitations.filter(i => i.opened_at).length %>
                            </div>
                            <div class="invite-stat-label">Opened</div>
                        </div>
                        <div class="invite-stat">
                            <div class="invite-stat-num" style="color:#48c78e;">
                                <%= invitations.filter(i => i.responded_at).length %>
                            </div>
                            <div class="invite-stat-label">Responded</div>
                        </div>
                    </div>
                    <% } %>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
.invite-section { padding: 40px 0 60px; }
.invite-stat {
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 12px;
    padding: 12px 20px;
    text-align: center;
    min-width: 80px;
}
.invite-stat-num { font-size: 1.4rem; font-weight: 700; color: #667eea; }
.invite-stat-label { font-size: 0.78rem; color: #a0a0c0; }
</style>

<script>
function copyShareUrl() {
    const url = document.getElementById('shareUrlDisplay').textContent.trim();
    navigator.clipboard.writeText(url).then(() => {
        const btn = event.target.closest('button');
        btn.innerHTML = '<i class="bi bi-check-circle-fill"></i>';
        setTimeout(() => btn.innerHTML = '<i class="bi bi-clipboard"></i>', 2000);
    });
}
</script>

<%- include('partials/footer') %>
